{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",

        "module": "nodenext",
        "target": "ES2022",
        "moduleResolution": "nodenext",

        "types": ["node"],

        "strict": true,
        "skipLibCheck": true,

        "esModuleInterop": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
